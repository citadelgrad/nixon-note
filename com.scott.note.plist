<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nixonnote.app</string>

    <!-- Public-safe LaunchAgent template. Replace __NIXONNOTE_ROOT__ before installing. -->
    <key>ProgramArguments</key>
    <array>
        <string>__NIXONNOTE_ROOT__/bin/note-service</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__NIXONNOTE_ROOT__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/nixonnote.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/nixonnote.stderr.log</string>

    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
