<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nixonnote.backup</string>

    <!-- Public-safe LaunchAgent template. Replace __NIXONNOTE_ROOT__ and __HOME__ before installing. -->
    <key>ProgramArguments</key>
    <array>
        <string>__NIXONNOTE_ROOT__/bin/note-backup</string>
    </array>

    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key>
            <integer>8</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>20</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/nixonnote.backup.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/nixonnote.backup.log</string>
</dict>
</plist>
